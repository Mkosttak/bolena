# Bolena2 — Örnek environment dosyası
# Bu dosyayı .env.local olarak kopyala ve değerleri Supabase Dashboard → Settings → API'den al.
# .env.local .gitignore'da — commit ETMA.

# ──────────────────────────────────────────────────────────────────────
# Public — tarayıcıya iner, sızıntı sorun değil
# ──────────────────────────────────────────────────────────────────────

# Supabase Project URL (Dashboard → Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key (Dashboard → Settings → API → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Sitenin canonical URL'i (sitemap, OG, robots için kullanılır)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ──────────────────────────────────────────────────────────────────────
# Server-only — KESİNLİKLE tarayıcıya inmemelidir
# ──────────────────────────────────────────────────────────────────────

# Supabase Service Role Key (Dashboard → Settings → API → service_role secret)
# Bu key RLS'i bypass eder — sadece güvenli server context'inde kullanılır.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ──────────────────────────────────────────────────────────────────────
# Opsiyonel — production observability ve özellikler
# ──────────────────────────────────────────────────────────────────────

# Sentry hata izleme (boş bırakılırsa devre dışı)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/yyy
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/yyy

# Custom log endpoint (Datadog/Logtail/Grafana Loki için)
# LOG_HTTP_ENDPOINT=https://logs.example.com/ingest

# Vercel Analytics / Speed Insights (auto, ekstra config gerekmez)

# Test için (CI'da set):
# SKIP_ENV_VALIDATION=true
# TEST_EMAIL=test@bolena.com
# TEST_PASSWORD=secure-test-password
